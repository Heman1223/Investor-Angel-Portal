# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL / Supabase)
# Use a direct connection for migrations (port 5432) 
# and a pooled connection for the app (port 6543) if using Supabase.
DATABASE_URL="postgresql://user:password@host:port/dbname?pgbouncer=true"

# JWT
JWT_SECRET=your-64-byte-random-secret-here-change-in-production
JWT_REFRESH_SECRET=your-64-byte-random-refresh-secret-here-change-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# File Storage
UPLOAD_DIR=./uploads
