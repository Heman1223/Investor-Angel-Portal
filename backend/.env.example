# Server Configuration
PORT=6001
NODE_ENV=development

# Database URIs
# Replace with your actual connection strings
MONGODB_URI=mongodb://localhost:27017/portfolioos
DATABASE_URL="postgresql://postgres:user@host:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres:user@host:5432/postgres?sslmode=require"

# JWT configuration
# Use strong random hex strings in production
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Cross-Origin Policies
FRONTEND_URL=http://localhost:5173

# Local File Storage (if used)
UPLOAD_DIR=./uploads

# Cloudinary Integration (for document storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret