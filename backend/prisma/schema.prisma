generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  INVESTOR
  COMPANY_USER
}

enum NotificationPreference {
  IMMEDIATE
  DIGEST
  MUTED
}

enum UpdateSource {
  INVESTOR_ENTERED
  COMPANY_SUBMITTED
}

enum UpdateStatus {
  DRAFT
  SUBMITTED
  PUBLISHED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model Investor {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  passwordHash         String
  role                 UserRole            @default(INVESTOR)
  notificationPreference NotificationPreference @default(IMMEDIATE)
  subscriptionTier     String              @default("free") // "free", "pro", "enterprise"
  twoFactorSecret      String?
  twoFactorEnabled     Boolean             @default(false)
  lastLoginAt          DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  tokenVersion         Int                 @default(0)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  alerts               Alert[]
  alertConfiguration   AlertConfiguration?
  auditLogs            AuditLog[]
  cashflows            Cashflow[]
  dilutionEvents       DilutionEvent[]
  documents            Document[]
  monthlyUpdates       MonthlyUpdate[]
  startups             Startup[]
  investments          Investment[]
  companyMemberships   CompanyMembership[]
  invitesSent          CompanyInvite[]     @relation("InvitesSent")
  updateReads          StartupUpdateRead[]
  updateRevisions      StartupUpdateRevision[]
  sentMessages         StartupMessage[]
  messageReads         StartupMessageRead[]
}

model Startup {
  id                   String              @id @default(cuid())
  investorId           String
  name                 String
  sector               String
  stage                String
  status               String              @default("active")
  entryValuation       Float
  currentValuation     Float
  equityPercent        Float
  currentEquityPercent Float
  investmentDate       DateTime
  description          String?
  website              String?
  founderName          String?
  founderEmail         String?
  notes                Json?
  coInvestors          String?
  updateDueDay         Int                 @default(10)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  alerts               Alert[]
  cashflows            Cashflow[]
  dilutionEvents       DilutionEvent[]
  documents            Document[]
  monthlyUpdates       MonthlyUpdate[]
  investor             Investor            @relation(fields: [investorId], references: [id])
  investments          Investment[]
  companyMemberships   CompanyMembership[]
  companyInvites       CompanyInvite[]
  conversation         StartupConversation?
}

// ─── Multi-Investor & Company Access ──────────────────────────────────────────

model Investment {
  id         String   @id @default(cuid())
  investorId String
  startupId  String
  amount     Float
  date       DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  investor   Investor @relation(fields: [investorId], references: [id])
  startup    Startup  @relation(fields: [startupId], references: [id])

  @@unique([investorId, startupId])
}

model CompanyMembership {
  id        String   @id @default(cuid())
  userId    String
  startupId String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  user      Investor @relation(fields: [userId], references: [id])
  startup   Startup  @relation(fields: [startupId], references: [id])

  @@unique([userId, startupId])
}

model CompanyInvite {
  id          String       @id @default(cuid())
  startupId   String
  invitedBy   String
  email       String
  token       String       @unique
  status      InviteStatus @default(PENDING)
  companyRole String       @default("member")
  invitedAt   DateTime     @default(now())
  resentAt    DateTime?
  acceptedAt  DateTime?
  revokedAt   DateTime?
  expiresAt   DateTime
  startup     Startup      @relation(fields: [startupId], references: [id])
  inviter     Investor     @relation("InvitesSent", fields: [invitedBy], references: [id])
}

// ─── Monthly Updates ──────────────────────────────────────────────────────────

model MonthlyUpdate {
  id              String       @id @default(cuid())
  startupId       String
  submittedBy     String
  month           String
  revenue         Float
  burnRate        Float
  cashBalance     Float
  runwayMonths    Float?
  valuationUpdate Float?
  notes           String?
  headcount       Int?
  keyWins         String?
  keyChallenges   String?
  helpNeeded      String?
  source          UpdateSource @default(INVESTOR_ENTERED)
  status          UpdateStatus @default(SUBMITTED)
  createdAt       DateTime     @default(now())
  startup         Startup      @relation(fields: [startupId], references: [id])
  investor        Investor     @relation(fields: [submittedBy], references: [id])
  reads           StartupUpdateRead[]
  revisions       StartupUpdateRevision[]

  @@unique([startupId, month])
}

model StartupUpdateRead {
  id         String        @id @default(cuid())
  updateId   String
  investorId String
  seenAt     DateTime      @default(now())
  update     MonthlyUpdate @relation(fields: [updateId], references: [id])
  investor   Investor      @relation(fields: [investorId], references: [id])

  @@unique([updateId, investorId])
}

model StartupUpdateRevision {
  id               String        @id @default(cuid())
  originalUpdateId String
  correctionNote   String
  changedFields    Json
  revenue          Float?
  burnRate         Float?
  cashBalance      Float?
  runwayMonths     Float?
  notes            String?
  submittedBy      String
  createdAt        DateTime      @default(now())
  originalUpdate   MonthlyUpdate @relation(fields: [originalUpdateId], references: [id])
  submitter        Investor      @relation(fields: [submittedBy], references: [id])
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model StartupConversation {
  id            String           @id @default(cuid())
  startupId     String           @unique
  createdAt     DateTime         @default(now())
  lastMessageAt DateTime         @default(now())
  startup       Startup          @relation(fields: [startupId], references: [id])
  messages      StartupMessage[]
}

model StartupMessage {
  id             String                     @id @default(cuid())
  conversationId String
  senderUserId   String
  body           String
  messageType    String                     @default("TEXT")
  createdAt      DateTime                   @default(now())
  conversation   StartupConversation        @relation(fields: [conversationId], references: [id])
  sender         Investor                   @relation(fields: [senderUserId], references: [id])
  attachments    StartupMessageAttachment[]
  reads          StartupMessageRead[]
}

model StartupMessageAttachment {
  id         String         @id @default(cuid())
  messageId  String
  fileName   String
  mimeType   String
  fileSize   Int
  storageKey String
  uploadedAt DateTime       @default(now())
  message    StartupMessage @relation(fields: [messageId], references: [id])
}

model StartupMessageRead {
  id        String         @id @default(cuid())
  messageId String
  userId    String
  seenAt    DateTime       @default(now())
  message   StartupMessage @relation(fields: [messageId], references: [id])
  user      Investor       @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

// ─── Financial & Analytics ────────────────────────────────────────────────────

model Cashflow {
  id              String   @id @default(cuid())
  investorId      String
  startupId       String
  amount          Float
  date            DateTime
  type            String
  roundName       String?
  valuationAtTime Float?
  equityAcquired  Float?
  currency        String   @default("INR")
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  investor        Investor @relation(fields: [investorId], references: [id])
  startup         Startup  @relation(fields: [startupId], references: [id])
}

model DilutionEvent {
  id                 String   @id @default(cuid())
  startupId          String
  investorId         String
  roundName          String
  date               DateTime
  preDilutionEquity  Float
  postDilutionEquity Float
  newInvestor        String?
  roundValuation     Float?
  notes              String?
  createdAt          DateTime @default(now())
  investor           Investor @relation(fields: [investorId], references: [id])
  startup            Startup  @relation(fields: [startupId], references: [id])
}

model Document {
  id            String   @id @default(cuid())
  startupId     String?
  investorId    String
  fileName      String
  fileKey       String   @unique
  fileSizeBytes Int
  mimeType      String
  documentType  String
  description   String?
  uploadedBy    String
  isArchived    Boolean  @default(false)
  uploadedAt    DateTime @default(now())
  investor      Investor @relation(fields: [investorId], references: [id])
  startup       Startup? @relation(fields: [startupId], references: [id])
}

// ─── Alerts & Config ──────────────────────────────────────────────────────────

model Alert {
  id          String    @id @default(cuid())
  investorId  String
  startupId   String
  alertType   String
  severity    String
  message     String
  isRead      Boolean   @default(false)
  triggeredAt DateTime  @default(now())
  resolvedAt  DateTime?
  investor    Investor  @relation(fields: [investorId], references: [id])
  startup     Startup   @relation(fields: [startupId], references: [id])
}

model AlertConfiguration {
  id                      String   @id @default(cuid())
  investorId              String   @unique
  runwayWarningMonths     Int      @default(6)
  runwayCriticalMonths    Int      @default(3)
  revenueDropWarningPct   Float    @default(15)
  updateOverdueDays       Int      @default(45)
  irrNegativeThresholdPct Float    @default(-20)
  moicWarningThreshold    Float    @default(0.75)
  updatedAt               DateTime @updatedAt
  investor                Investor @relation(fields: [investorId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  investorId String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  investor   Investor @relation(fields: [investorId], references: [id])
}
