generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Investor {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  passwordHash         String
  role                 String              @default("investor")
  subscriptionTier     String              @default("solo")
  twoFactorSecret      String?
  twoFactorEnabled     Boolean             @default(false)
  lastLoginAt          DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  alerts               Alert[]
  alertConfiguration   AlertConfiguration?
  auditLogs            AuditLog[]
  cashflows            Cashflow[]
  dilutionEvents       DilutionEvent[]
  documents            Document[]
  monthlyUpdates       MonthlyUpdate[]
  startups             Startup[]
}

model Startup {
  id                   String          @id @default(cuid())
  investorId           String
  name                 String
  sector               String
  stage                String
  status               String          @default("active")
  entryValuation       Float
  currentValuation     Float
  equityPercent        Float
  currentEquityPercent Float
  investmentDate       DateTime
  description          String?
  website              String?
  founderName          String?
  founderEmail         String?
  notes                Json?
  coInvestors          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  alerts               Alert[]
  cashflows            Cashflow[]
  dilutionEvents       DilutionEvent[]
  documents            Document[]
  monthlyUpdates       MonthlyUpdate[]
  investor             Investor        @relation(fields: [investorId], references: [id])
}

model MonthlyUpdate {
  id              String   @id @default(cuid())
  startupId       String
  submittedBy     String
  month           String
  revenue         Float
  burnRate        Float
  cashBalance     Float
  runwayMonths    Float?
  valuationUpdate Float?
  notes           String?
  headcount       Int?
  keyWins         String?
  keyChallenges   String?
  helpNeeded      String?
  createdAt       DateTime @default(now())
  startup         Startup  @relation(fields: [startupId], references: [id])
  investor        Investor @relation(fields: [submittedBy], references: [id])

  @@unique([startupId, month])
}

model Cashflow {
  id              String   @id @default(cuid())
  investorId      String
  startupId       String
  amount          Float
  date            DateTime
  type            String
  roundName       String?
  valuationAtTime Float?
  equityAcquired  Float?
  currency        String   @default("INR")
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  investor        Investor @relation(fields: [investorId], references: [id])
  startup         Startup  @relation(fields: [startupId], references: [id])
}

model DilutionEvent {
  id                 String   @id @default(cuid())
  startupId          String
  investorId         String
  roundName          String
  date               DateTime
  preDilutionEquity  Float
  postDilutionEquity Float
  newInvestor        String?
  roundValuation     Float?
  notes              String?
  createdAt          DateTime @default(now())
  investor           Investor @relation(fields: [investorId], references: [id])
  startup            Startup  @relation(fields: [startupId], references: [id])
}

model Document {
  id            String   @id @default(cuid())
  startupId     String?
  investorId    String
  fileName      String
  fileKey       String   @unique
  fileSizeBytes Int
  mimeType      String
  documentType  String
  description   String?
  uploadedBy    String
  isArchived    Boolean  @default(false)
  uploadedAt    DateTime @default(now())
  investor      Investor @relation(fields: [investorId], references: [id])
  startup       Startup? @relation(fields: [startupId], references: [id])
}

model Alert {
  id          String    @id @default(cuid())
  investorId  String
  startupId   String
  alertType   String
  severity    String
  message     String
  isRead      Boolean   @default(false)
  triggeredAt DateTime  @default(now())
  resolvedAt  DateTime?
  investor    Investor  @relation(fields: [investorId], references: [id])
  startup     Startup   @relation(fields: [startupId], references: [id])
}

model AlertConfiguration {
  id                      String   @id @default(cuid())
  investorId              String   @unique
  runwayWarningMonths     Int      @default(6)
  runwayCriticalMonths    Int      @default(3)
  revenueDropWarningPct   Float    @default(15)
  updateOverdueDays       Int      @default(45)
  irrNegativeThresholdPct Float    @default(-20)
  moicWarningThreshold    Float    @default(0.75)
  updatedAt               DateTime @updatedAt
  investor                Investor @relation(fields: [investorId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  investorId String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  investor   Investor @relation(fields: [investorId], references: [id])
}
